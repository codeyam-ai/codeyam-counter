    "itemShape": {
      "changeWithoutVerify": "note",
      "compound": "warning",
      "vague": "warning"
    },
    "scenarioFreshnessDays": 14,
    "stepBudget": {
      "maxChecklistItems": 6,
      "maxLines": 80,
      "severity": "warning"
    },
    "testNamingConventions": {}
  },
  "catalogAutoAdd": {
    "allow": [],
    "deny": []
  },
  "cleanup": {
    "completedPlanRetention": 20,
    "logCompress": true,
    "logDeleteDays": 30,
    "logRotateDays": 7,
    "screenshotPruneOrphans": true,
    "tmpDeleteHours": 24
  },
  "coverageThresholds": {
    "global": {
      "minLinePercent": 90.0
    }
  },
  "database": null,
  "defaultScreenSize": "iPhone 16",
  "env": {},
  "files": {
    "eventLogMaxBytes": null,
    "journalShardEntries": null,
    "logKeepRotated": null,
    "textLogMaxBytes": null
  },
  "formatters": [],
  "git": {
    "commitQueue": {
      "enabled": true,
      "heartbeatIntervalSec": 15,
      "machineAliveHookTimeoutMs": 5000,
      "maxHookPrunePerSweep": 10,
      "maxProgressStallSec": 900,
      "pollIntervalMs": 2000,
      "serverHeartbeatIntervalSec": 60,
      "waitTimeoutSec": 300
    },
    "planClaims": {
      "enabled": true,
      "fetchIntervalSec": 3
    }
  },
  "hooks": {},
  "port": 3000,
  "projectDescription": "Can we create a mobile counter app? I have mockups to demonstrate the first page.\n",
  "projectTitle": "CodeYam Counter",
  "provider": "claude",
  "proxy": {
    "controlPort": 14199,
    "dbPort": 14101,
    "httpPort": 14100,
    "httpsPassthrough": [],
    "httpsPreview": false
  },
  "runnerTimeout": {
    "floorSeconds": 900,
    "headroomSeconds": 90,
    "mode": "auto"
  },
  "scenarios": {
    "dir": ".codeyam/scenarios"
  },
  "screenSizes": {
    "iPad": {
      "height": 1180,
      "width": 820
    },
    "iPhone 16": {
      "height": 852,
      "width": 393
    }
  },
  "server": {
    "autoRestartOnStaleBinary": true,
    "maxRssMb": 6144
  },
  "silenceHookStderr": false,
  "startCommand": "",
  "staticChecks": [
    {
      "command": "swift build --package-path ios",
      "description": "Build / compile check (swift build)",
      "excludePatterns": [
        "**/.build/**",
        "**/build/**",
        "**/.gradle/**"
      ],
      "filePatterns": [
        "**/*.swift"
      ],
      "name": "build"
    }
  ],
  "testParallelism": {
    "loadGuard": true
  },
  "testPartitions": [],
  "testRunners": [
    {
      "command": "swift test --package-path ios --parallel --disable-swift-testing --xunit-output .codeyam/swift-tests.xml",
      "excludePatterns": [
        "**/.build/**",
        "**/build/**"
      ],
      "name": "tests",
      "outputFormat": "junit-xml",
      "outputPath": ".codeyam/swift-tests.xml",
      "sourceFilePatterns": [
        "**/*.swift"
      ],
      "targetedCommand": "swift test --package-path ios --parallel --disable-swift-testing --xunit-output .codeyam/swift-tests.xml --filter \"{test_names}\"",
      "testFilePatterns": [
        "**/Tests/**/*.swift",
        "**/*Tests.swift"
      ]
    }
  ]
}