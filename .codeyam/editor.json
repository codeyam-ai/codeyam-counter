    "stepBudget": {
      "maxLines": 80,
      "maxChecklistItems": 6,
      "severity": "warning"
    },
    "itemShape": {
      "compound": "warning",
      "vague": "warning",
      "changeWithoutVerify": "note"
    },
    "allowedDocumentationOnlySlugs": [
      "post-merge-drift-sweep"
    ],
    "scenarioFreshnessDays": 14,
    "branchBaseRef": "main",
    "coverageBootstrap": {
      "enabled": true
    }
  },
  "coverageThresholds": {
    "global": {
      "minLinePercent": 90.0
    }
  },
  "catalogAutoAdd": {
    "allow": [],
    "deny": []
  },
  "testParallelism": {
    "loadGuard": true
  },
  "cleanup": {
    "logRotateDays": 7,
    "logDeleteDays": 30,
    "logCompress": true,
    "tmpDeleteHours": 24,
    "screenshotPruneOrphans": true,
    "completedPlanRetention": 20
  },
  "runnerTimeout": {
    "mode": "auto",
    "headroomSeconds": 90,
    "floorSeconds": 900,
    "changedFanoutThreshold": 2,
    "changedFanoutPerUnitSeconds": 180,
    "changedFanoutMaxExtraSeconds": 1800
  },
  "silenceHookStderr": false,
  "git": {
    "commitQueue": {
      "enabled": true,
      "pollIntervalMs": 2000,
      "waitTimeoutSec": 300,
      "heartbeatIntervalSec": 15,
      "serverHeartbeatIntervalSec": 60,
      "machineAliveHookTimeoutMs": 5000,
      "maxHookPrunePerSweep": 10,
      "maxProgressStallSec": 900
    },
    "planClaims": {
      "enabled": true,
      "fetchIntervalSec": 3
    }
  },
  "server": {
    "autoRestartOnStaleBinary": true,
    "maxRssMb": 6144
  },
  "setupBrowserEnabled": false,
  "workflow": {
    "checkIns": {
      "planAccepted": {
        "pause": true
      },
      "prototypeCompleted": {
        "pause": true
      },
      "hardeningCompleted": {
        "pause": true,
        "autoAction": "commit"
      },
      "push": {
        "pause": true
      }
    }
  }
