{
  "$comment": "Per-developer settings (port, provider, proxy ports, startCommand, etc.) belong in editor.local.json. That file is gitignored and is deep-merged on top of this one at load time. See CLAUDE.md or run `codeyam-editor editor config-show` to inspect the effective config.",
  "projectTitle": "CodeYam Counter",
  "projectDescription": "Can we create a mobile counter app? I have mockups to demonstrate the first page.\n",
  "provider": "claude",
  "startCommand": "",
  "port": 3000,
  "env": {},
  "toolchainPaths": [],
  "proxy": {
    "httpPort": 14100,
    "dbPort": 14101,
    "controlPort": 14199,
    "httpsPassthrough": [],
    "httpsPreview": false
  },
  "database": null,
  "scenarios": {
    "dir": ".codeyam/scenarios"
  },
  "hooks": {},
  "testRunners": [
    {
      "name": "tests",
      "command": "swift test --package-path ios --parallel --disable-swift-testing --xunit-output .codeyam/swift-tests.xml",
      "outputFormat": "junit-xml",
      "outputPath": ".codeyam/swift-tests.xml",
      "testFilePatterns": [
        "**/Tests/**/*.swift",
        "**/*Tests.swift"
      ],
      "sourceFilePatterns": [
        "**/*.swift"
      ],
      "excludePatterns": [
        "**/.build/**",
        "**/build/**"
      ],
      "coverageExcludePaths": [],
      "targetedCommand": "swift test --package-path ios --parallel --disable-swift-testing --xunit-output .codeyam/swift-tests.xml --filter \"{test_names}\""
    },
    {
      "name": "android-tests",
      "command": "android/gradlew -p android test --rerun-tasks && python3 android/scripts/merge-test-results.py android/app/build/test-results/testDebugUnitTest .codeyam/android-tests.xml",
      "outputFormat": "junit-xml",
      "outputPath": ".codeyam/android-tests.xml",
      "testFilePatterns": [
        "android/**/src/test/**/*.kt",
        "android/**/*Test.kt"
      ],
      "sourceFilePatterns": [
        "android/**/*.kt"
      ],
      "excludePatterns": [
        "**/.gradle/**",
        "**/build/**"
      ],
      "coverageExcludePaths": [],
      "targetedCommand": "android/gradlew -p android test --rerun-tasks --tests \"{test_names}\" && python3 android/scripts/merge-test-results.py android/app/build/test-results/testDebugUnitTest .codeyam/android-tests.xml"
    }
  ],
  "testPartitions": [],
  "staticChecks": [
    {
      "name": "build",
      "command": "swift build --package-path ios",
      "filePatterns": [
        "**/*.swift"
      ],
      "excludePatterns": [
        "**/.build/**",
        "**/build/**",
        "**/.gradle/**"
      ],
      "description": "Build / compile check (swift build)"
    },
    {
      "name": "android-build",
      "command": "android/gradlew -p android compileDebugKotlin",
      "filePatterns": [
        "android/**/*.kt",
        "android/**/*.kts"
      ],
      "excludePatterns": [
        "**/.gradle/**",
        "**/build/**"
      ],
      "description": "Android build / compile check (Gradle compileDebugKotlin)"
    }
  ],
  "formatters": [],
  "screenSizes": {
    "iPad": {
      "width": 820,
      "height": 1180
    },
    "iPhone 16": {
      "width": 393,
      "height": 852
    }
  },
  "defaultScreenSize": "iPhone 16",
  "apps": [
    {
      "name": "CodeYam Counter",
      "type": "mobile",
      "dir": "ios"
    },
    {
      "name": "CodeYam Counter (Android)",
      "type": "mobile",
      "dir": "android"
    }
  ],
  "files": {
    "textLogMaxBytes": null,
    "eventLogMaxBytes": null,
    "logKeepRotated": null,
    "journalShardEntries": null
  },
