{
  "capabilities": {
    "http-mocks": "verified",
    "interactions-click": "verified",
    "interactions-touch-gestures": "manual",
    "layout-web": "not-applicable",
    "native-clipboard": "manual",
    "native-geolocation": "manual",
    "native-haptics": "manual",
    "native-network": "manual",
    "native-storage": "verified",
    "real-device": "manual",
    "routing": "manual"
  },
  "commands": {
    "dev": "android/gradlew -p android installDebug",
    "test": "android/gradlew -p android test"
  },
  "components": {
    "fileExtensions": [
      ".kt"
    ]
  },
  "data": {
    "type": "observable-model"
  },
  "defaultScreenSize": "Phone Portrait",
  "id": "kotlin-android-compose",
  "name": "Kotlin + Jetpack Compose (Android)",
  "preview": {
    "kind": "simulator-android"
  },
  "screenSizes": {
    "Phone Landscape": {
      "height": 393,
      "width": 852
    },
    "Phone Portrait": {
      "height": 852,
      "width": 393
    },
    "Tablet Landscape": {
      "height": 820,
      "width": 1180
    },
    "Tablet Portrait": {
      "height": 1180,
      "width": 820
    }
  },
  "simulator": {
    "buildSignalRegex": "(BUILD SUCCESSFUL|Successfully built|Launching app|Successfully installed)",
    "platform": "android",
    "preflightChecks": [
      "adb-installed",
      "emulator-installed",
      "avd-present"
    ],
    "runCommand": [
      "android/gradlew",
      "-p",
      "android",
      "installDebug"
    ]
  },
  "toolchain": [
    {
      "detect": {
        "absentIfOutputContains": [
          "No Java runtime present"
        ],
        "argv": [
          "java",
          "-version"
        ],
        "kind": "command"
      },
      "id": "java",
      "install": {
        "cmd": "brew install --cask temurin@17",
        "estCost": "~300 MB, ~2 min"
      },
      "label": "Java 17+ runtime (JDK)"
    },
    {
      "detect": {
        "kind": "env",
        "name": "ANDROID_HOME"
      },
      "id": "android-sdk",
      "install": {
        "cmd": "brew install android-commandlinetools && sdkmanager 'platform-tools' 'platforms;android-34'",
        "estCost": "~1\u20132 GB, 5\u201315 min"
      },
      "label": "Android SDK (ANDROID_HOME)"
    },
    {
      "detect": {
        "kind": "file",
        "path": "android/gradlew"
      },
      "id": "gradlew",
      "label": "Gradle wrapper present"
    }
  ]
}
